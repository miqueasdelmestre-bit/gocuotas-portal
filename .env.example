# URL del material de comunicación descargable tras enviar una solicitud.
NEXT_PUBLIC_MATERIAL_DOWNLOAD_URL=https://gocuotas.com/material-comunicacion

# Base URL para un futuro backend propio (auth, DB, integraciones). Vacío = no usado todavía.
NEXT_PUBLIC_API_BASE_URL=

# API key de Google Maps (Places API) para el autocompletado de direcciones
# en el pedido de material físico. Sin esta key, el campo de dirección
# funciona igual pero como texto libre (sin autocompletar).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

